    <main class="pt-32 pb-12 px-6 max-w-[1440px] mx-auto">
        <!-- Header -->
        <div class="mb-8 flex justify-between items-end">
            <div>
                <h1 class="font-h1 text-h1 text-on-surface">Articles</h1>
                <p class="font-body-md text-on-surface-variant">Manage all platform articles and content</p>
            </div>
            <div class="flex gap-4">
                <div class="bg-white px-4 py-3 border border-slate-200 rounded-xl flex items-center gap-6 shadow-sm">
                    <div class="flex flex-col">
                        <span class="font-label-caps text-label-caps text-on-surface-variant">PUBLISHED</span>
                        <span class="font-display-stat text-[24px] text-on-surface">1,248</span>
                    </div>
                    <div class="w-px h-8 bg-slate-100"></div>
                    <div class="flex flex-col">
                        <span class="font-label-caps text-label-caps text-on-surface-variant">DRAFTS</span>
