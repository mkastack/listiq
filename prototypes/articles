                    <div class="w-px h-8 bg-slate-100"></div>
                    <div class="flex flex-col">
                        <span class="font-label-caps text-label-caps text-on-surface-variant">AI GENERATED</span>
                        <span class="font-display-stat text-[24px] text-primary">856</span>
                    </div>
                </div>
            </div>
        </div>
        <!-- Action Bar -->
