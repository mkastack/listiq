                </div>
                <select
                    class="border border-slate-200 rounded-lg py-2 px-3 text-body-md bg-white text-on-surface-variant focus:ring-2 focus:ring-primary outline-none">
                    <option>All Status</option>
                    <option>Published</option>
                    <option>Draft</option>
                    <option>Review Needed</option>
                </select>
                <select
                    class="border border-slate-200 rounded-lg py-2 px-3 text-body-md bg-white text-on-surface-variant focus:ring-2 focus:ring-primary outline-none">
                    <option>All Authors</option>
                    <option>System AI</option>
                    <option>Editorial Team</option>
                </select>
            </div>
            <div class="flex items-center gap-3">
                <button
