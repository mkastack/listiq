                    "borderRadius": {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    "spacing": {
                        "element-gap": "12px",
                        "max-width": "1440px",
                        "grid-columns": "12",
                        "card-gap": "24px",
                        "unit": "4px",
                        "container-padding": "32px"
                    },
                    "fontFamily": {
                        "body-sm": ["Manrope"],
                        "label-caps": ["Manrope"],
                        "body-md": ["Manrope"],
